    "<h1 style=\"font-size:300%\">HOUSE PRICE PREDICTOR</h1>\n",
    "\n",
    "This notebook is a starting point for a regression model that predicts house prices based on features of those houses. It uses the Boston House price dataset which is included in this repo as a csv file and represents prices of houses in the city of Boston in the 1970s. The data for this example is included in the git repo, so you can just clone this repo and run the notebook.\n",
    "\n",
    "Bas S.H.T. Michielsen, 2025"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Comparison: sklearn linear regression vs neural network (if available)\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import r2_score, mean_squared_error\n",
    "import numpy as np, glob, os, torch\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Recompute baseline on the same scaled data (variables X_train, y_train, X_test, y_test exist above)\n",
    "baseline = LinearRegression()\n",
    "baseline.fit(X_train, y_train)\n",
    "y_pred_baseline = baseline.predict(X_test)\n",
    "baseline_r2 = r2_score(y_test, y_pred_baseline)\n",
    "baseline_rmse = np.sqrt(mean_squared_error(y_test, y_pred_baseline))\n",
    "\n",
    "print(\"Linear Regression baseline R²:\", baseline_r2)\n",
    "print(\"Linear Regression baseline RMSE (k$):\", baseline_rmse)\n",
    "\n",
    "# Neural network metrics: prefer `score` from trainer.test(), else try loading latest checkpoint\n",
    "nn_available = False\n",
    "nn_rmse = None\n",
    "if 'score' in globals():\n",
    "    try:\n",
    "        nn_r2 = score[0]['test_r2']\n",
    "        # try to compute RMSE from `df` if predictions were already created\n",
    "        if 'df' in globals() and 'prediction' in df.columns:\n",
    "            nn_rmse = np.sqrt(mean_squared_error(df['truth'], df['prediction']))\n",
    "        nn_available = True\n",
    "    except Exception:\n",
    "        nn_available = False\n",
    "\n",
    "if not nn_available:\n",
    "    ckpts = glob.glob(os.path.join('lightning_logs', '**', 'checkpoints', '*.ckpt'), recursive=True)\n",
    "    if ckpts:\n",
    "        ckpt = max(ckpts, key=os.path.getmtime)\n",
    "        print('Loading checkpoint', ckpt)\n",
    "        model = RegressionModel.load_from_checkpoint(ckpt, num_features=train_ds.num_features())\n",
    "        trainer = L.Trainer(logger=False, enable_checkpointing=False)\n",
    "        dataloader = datamodule.test_dataloader()\n",
    "        output = trainer.predict(model, dataloaders=dataloader)\n",
    "        preds = torch.cat(output).cpu().numpy()\n",
    "        nn_r2 = r2_score(y_test, preds)\n",
    "        nn_rmse = np.sqrt(mean_squared_error(y_test, preds))\n",
    "        nn_available = True\n",
    "\n",
    "if nn_available:\n",
    "    print('Neural network R²:', nn_r2)\n",
    "    if nn_rmse is not None:\n",
    "        print('Neural network RMSE (k$):', nn_rmse)\n",
    "    else:\n",
    "        print('Neural network RMSE not available in this session')\n",
    "else:\n",
    "    print('Neural network metrics not available in this session; run training or ensure checkpoint exists.')\n",
    "\n",
    "# Small comparison plot\n",
    "labels = ['Baseline', 'NeuralNet'] if nn_available else ['Baseline']\n",
    "r2_vals = [baseline_r2] + ([nn_r2] if nn_available else [])\n",
    "rmse_vals = [baseline_rmse] + ([nn_rmse] if (nn_available and nn_rmse is not None) else [])\n",
    "fig, axes = plt.subplots(1,2, figsize=(10,4))\n",
    "axes[0].bar(labels, r2_vals, color=['C0','C1'][:len(labels)])\n",
    "axes[0].set_title('R²')\n",
    "axes[1].bar(labels, rmse_vals, color=['C0','C1'][:len(labels)])\n",
    "axes[1].set_title('RMSE (k$)')\n",
    "plt.tight_layout()"
   ]
  },
