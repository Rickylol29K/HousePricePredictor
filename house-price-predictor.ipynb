   "source": [
    "from lightning.pytorch.loggers import CSVLogger\n",
    "from lightning.pytorch.callbacks import EarlyStopping\n",
    "\n",
    "logger = CSVLogger(save_dir=\".\")\n",
    "stop = EarlyStopping(monitor=\"val_loss\", mode=\"min\")\n",
    "trainer = L.Trainer(logger=logger, max_epochs=-1, callbacks=[stop], log_every_n_steps=10)\n",
    "trainer.fit(model, datamodule=datamodule)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Evaluation\n",
    "Now that the model finished training, let's evaluate it. First we can plot the logged valiation loss and see that it has reached its minimum."
