    "class TabularDataset(D.TensorDataset):\n",
    "    \"\"\"TabularDataSet loads data from a pandas DataFrame assuming the last column is the target and all other columns are features that can be converted to float.\"\"\"\n",
    "    def __init__(self, dataframe: pandas.DataFrame):\n",
    "        rows = dataframe.values.astype(float)\n",
    "        data = torch.tensor(rows, dtype=torch.float32)\n",
    "        super().__init__(data[:, :-1], data[:, -1])\n",
    "    \n",
    "    def num_features(self) -> int:\n",
    "        return self[0][0].size()[0]\n",
    "\n",
    "\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "df = pandas.read_csv(data_path)\n",
    "\n",
    "# 1) split indices first (so scaler is fit ONLY on train)\n",
    "train_df = df.sample(frac=0.6, random_state=42)\n",
    "remaining_df = df.drop(train_df.index)\n",
    "\n",
    "val_df = remaining_df.sample(frac=0.75, random_state=42)  # 0.75 * 0.4 = 0.3\n",
    "test_df = remaining_df.drop(val_df.index)                  # 0.1\n",
    "\n",
    "# 2) fit scaler on TRAIN features only, then transform val/test\n",
    "scaler = StandardScaler()\n",
    "\n",
    "X_train = scaler.fit_transform(train_df.iloc[:, :-1])\n",
    "X_val   = scaler.transform(val_df.iloc[:, :-1])\n",
    "X_test  = scaler.transform(test_df.iloc[:, :-1])\n",
    "\n",
    "y_train = train_df.iloc[:, -1].values\n",
    "y_val   = val_df.iloc[:, -1].values\n",
    "y_test  = test_df.iloc[:, -1].values\n",
    "\n",
    "# 3) rebuild scaled dataframes (keep same column structure)\n",
    "train_scaled = pd.DataFrame(X_train, columns=df.columns[:-1])\n",
    "train_scaled[df.columns[-1]] = y_train\n",
    "\n",
    "val_scaled = pd.DataFrame(X_val, columns=df.columns[:-1])\n",
    "val_scaled[df.columns[-1]] = y_val\n",
    "\n",
    "test_scaled = pd.DataFrame(X_test, columns=df.columns[:-1])\n",
    "test_scaled[df.columns[-1]] = y_test\n",
    "\n",
    "# 4) create datasets from the scaled dataframes\n",
    "train_ds = TabularDataset(train_scaled)\n",
    "val_ds   = TabularDataset(val_scaled)\n",
    "test_ds  = TabularDataset(test_scaled)\n",
    "\n",
    "datamodule = L.LightningDataModule.from_datasets(\n",
    "    train_ds, val_ds, test_ds,\n",
    "    batch_size=32, num_workers=0\n",
    ")\n",
    "\n",
    "print(\"Created a DataModule with:\",\n",
    "      len(datamodule.train_dataloader().dataset), \"training items,\",\n",
    "      len(datamodule.val_dataloader().dataset), \"validation items and\",\n",
    "      len(datamodule.test_dataloader().dataset), \"test items.\")"
   ]
  },
